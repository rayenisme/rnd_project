{
    "version": 2,
    "framework": null,
    "functions": {
        "api/*.php": { 
            "runtime": "vercel-php@0.9.0",
            "excludeFiles": "{node_modules,tests,storage/framework/cache}"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "public": true,
    "buildCommand": "vite build",
    "outputDirectory": "public"
}